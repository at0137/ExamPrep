.DS_Store
*.env
*/__pycache__
.claude/settings.local.json
# keep only CIPM/LV1/translated_html
CIPM/*
!CIPM/LV1/
CIPM/LV1/*
!CIPM/LV1/translated_html/

# keep only CFA/LV1/translated_html
CFA/*
!CFA/LV1/
CFA/LV1/*
!CFA/LV1/translated_html/

references/*.pdf

# ── 論文翻訳 (Papers) ──
# marker 用の作業 venv（巨大なので追跡しない）
.venv-marker/
# 原本PDF は references/ に置く（references/*.pdf で既に除外済み・著作物）
# ページ画像・サンプルは再生成可能なので追跡しない
Papers/*/pages_png/
Papers/sample/
Papers/_compare/
# 和訳済み Markdown と README は追跡する（= サイトの元データ）
!Papers/*/translated_md/
